rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Inquiry schema validator
    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
        && data.keys().size() >= 4
        && data.keys().size() <= 6
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.message is string && data.message.size() > 0 && data.message.size() <= 5000
        && data.createdAt == request.time
        && (!('subject' in data) || (data.subject is string && data.subject.size() <= 200))
        && (!('id' in data) || (data.id is string && data.id.size() <= 128));
    }

    // Session schema validator
    function isValidSession(data) {
      return data.keys().hasAll(['id', 'userId', 'createdAt', 'updatedAt'])
        && data.keys().size() == 4
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.userId == request.auth.uid
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // ChatMessage schema validator
    function isValidChatMessage(data) {
      return data.keys().hasAll(['id', 'role', 'text', 'timestamp'])
        && data.keys().size() == 4
        && data.id is string && data.id.size() <= 128
        && data.role is string && (data.role == 'user' || data.role == 'model')
        && data.text is string && data.text.size() <= 10000
        && data.timestamp is timestamp;
    }

    // Match rules
    match /inquiries/{inquiryId} {
      allow create: if isValidId(inquiryId) && isValidInquiry(incoming());
      allow read, update, delete: if false; // PII Isolation / No public list or reading
    }

    match /sessions/{sessionId} {
      allow create: if isValidId(sessionId) && isSignedIn() && isValidSession(incoming()) && incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isValidId(sessionId) && isSignedIn() && isValidSession(incoming())
                       && existing().userId == request.auth.uid
                       && incoming().createdAt == existing().createdAt
                       && incoming().updatedAt == request.time;
      allow delete: if false; // Retention integrity

      match /messages/{messageId} {
        allow create: if isValidId(messageId) && isSignedIn()
                         && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid
                         && isValidChatMessage(incoming())
                         && incoming().timestamp == request.time;
        allow get, list: if isSignedIn() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
        allow update, delete: if false; // Chat histories are append-only and immutable once sent
      }
    }
  }
}
